generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SnapshotStatus {
  DRAFT
  PUBLISHED
}

model PortfolioSnapshot {
  id          String         @id @default(cuid())
  locale      String         @db.VarChar(5)
  status      SnapshotStatus @default(PUBLISHED)
  payload     Json
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([locale, status])
  @@index([status])
}

// Immutable, append-only history of published content. One row is written per
// publish so a previous version can be restored if a publish goes wrong.
model PortfolioPublication {
  id          String   @id @default(cuid())
  locale      String   @db.VarChar(5)
  version     Int
  payload     Json
  publishedAt DateTime @default(now())

  @@unique([locale, version])
  @@index([locale, publishedAt])
}